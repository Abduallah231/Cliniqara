generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  DOCTOR
  RECEPTION
}

enum DoctorLevel {
  INTERN
  DOCTOR
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                      String               @id @default(uuid())
  userCode                String               @unique
  accountType             AccountType
  doctorLevel             DoctorLevel?

  fullName                String

  email                   String               @unique
  phone                   String               @unique

  passwordHash            String

  nationalId              String?
  medicalLicenseNumber    String?              @unique

  nationalIdImage         String?
  medicalCardImage        String?

  emailVerified           Boolean              @default(false)
  phoneVerified           Boolean              @default(false)

  verificationStatus      VerificationStatus   @default(PENDING)

  isActive                Boolean              @default(true)

  lastLoginAt             DateTime?

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  createdClinics Clinic[] @relation("ClinicOwner")
  clinicMemberships  ClinicMember[]

  @@index([accountType])
  @@index([verificationStatus])

  @@map("users")
  }
  
model Clinic {
  id                  String      @id @default(uuid())

  clinicCode          String      @unique

  name                String

  phone               String      @unique

  email               String?

  address             String

  country             String

  city                String

  workingDays         ClinicWorkingDay[]

  isActive            Boolean     @default(true)

  createdById         String

  createdBy User @relation("ClinicOwner", fields: [createdById], references: [id])

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  members             ClinicMember[]
  patients            Patient[]

  @@index([createdById])
  @@index([city])

  @@map("clinics")
}

enum ClinicRole {
  OWNER
  DOCTOR
  RECEPTION
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum WeekDay {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model ClinicMember {
  id                  String              @id @default(uuid())

  clinicId            String
  userId              String

  clinicRole          ClinicRole
  status              MembershipStatus    @default(ACTIVE)

  joinedAt            DateTime            @default(now())
  removedAt           DateTime?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  clinic              Clinic              @relation(fields: [clinicId], references: [id])
  user                User                @relation(fields: [userId], references: [id])

  @@unique([clinicId, userId])

  @@index([clinicId])
  @@index([userId])
  @@index([clinicRole])

  @@map("clinic_members")
}

enum Gender {
  MALE
  FEMALE
}

model ClinicWorkingDay {
  id         String   @id @default(uuid())

  clinicId   String

  day        WeekDay

  startTime  String

  endTime    String

  isClosed   Boolean  @default(false)

  clinic     Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, day])

  @@index([clinicId])

  @@map("clinic_working_days")
}

model Patient {
  id                String      @id @default(uuid())

  patientCode       String

  clinicId          String

  fullName          String

  nationalId        String?

  dateOfBirth       DateTime

  gender            Gender

  phone             String?

  address           String?

  occupation        String?

  maritalStatus     String?

  childrenCount     Int         @default(0)

  notes             String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  clinic            Clinic      @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, patientCode])

  @@index([clinicId])
  @@index([fullName])
  @@index([phone])

  @@map("patients")
}