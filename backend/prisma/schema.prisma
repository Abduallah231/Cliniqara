generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  DOCTOR
  RECEPTION
}

enum DoctorLevel {
  INTERN
  DOCTOR
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                      String               @id @default(uuid())
  userCode                String               @unique
  accountType             AccountType
  doctorLevel             DoctorLevel?

  fullName                String

  email                   String               @unique
  phone                   String               @unique

  passwordHash            String

  nationalId              String?
  medicalLicenseNumber    String?              @unique

  nationalIdImage         String?
  medicalCardImage        String?

  emailVerified           Boolean              @default(false)
  phoneVerified           Boolean              @default(false)

  verificationStatus      VerificationStatus   @default(PENDING)

  isActive                Boolean              @default(true)

  lastLoginAt             DateTime?

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  createdClinics Clinic[] @relation("ClinicOwner")
  clinicMemberships  ClinicMember[]
  visits Visit[]

  @@index([accountType])
  @@index([verificationStatus])

  @@map("users")
  }
  
model Clinic {
  id                  String      @id @default(uuid())

  clinicCode          String      @unique

  name                String

  phone               String      @unique

  email               String?

  address             String

  country             String

  city                String

  workingDays         ClinicWorkingDay[]

  isActive            Boolean     @default(true)

  createdById         String

  createdBy User @relation("ClinicOwner", fields: [createdById], references: [id])

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  members             ClinicMember[]
  patients            Patient[]
  visits              Visit[]

  @@index([createdById])
  @@index([city])

  @@map("clinics")
}

enum ClinicRole {
  OWNER
  DOCTOR
  RECEPTION
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum WeekDay {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model ClinicMember {
  id                  String              @id @default(uuid())

  clinicId            String
  userId              String

  clinicRole          ClinicRole
  status              MembershipStatus    @default(ACTIVE)

  joinedAt            DateTime            @default(now())
  removedAt           DateTime?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  clinic              Clinic              @relation(fields: [clinicId], references: [id])
  user                User                @relation(fields: [userId], references: [id])

  @@unique([clinicId, userId])

  @@index([clinicId])
  @@index([userId])
  @@index([clinicRole])

  @@map("clinic_members")
}

enum Gender {
  MALE
  FEMALE
}

enum PatientIdentifierType {
  NATIONAL_ID
  BIRTH_CERTIFICATE
  PASSPORT
  OTHER
  UNKNOWN
}

enum AgeUnit {
  YEARS
  MONTHS
  DAYS
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

model ClinicWorkingDay {
  id         String   @id @default(uuid())

  clinicId   String

  day        WeekDay

  startTime  String

  endTime    String

  isClosed   Boolean  @default(false)

  clinic     Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, day])

  @@index([clinicId])

  @@map("clinic_working_days")
}

model Patient {
  id                String      @id @default(uuid())

  patientCode       String

  clinicId          String

  fullName          String

  identifierType    PatientIdentifierType

  identifierNumber  String?

  dateOfBirth DateTime?

  estimatedAgeValue Int?

  estimatedAgeUnit AgeUnit?

  maritalStatus     MaritalStatus

  governorate       String?

  city              String?

  district          String?

  streetAddress     String?
  
  gender            Gender

  phone             String?

  occupation        String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  clinic            Clinic      @relation(fields: [clinicId], references: [id])

  visits Visit[]

  @@unique([clinicId, patientCode])

  @@index([clinicId])
  @@index([fullName])
  @@index([phone])

  @@map("patients")
}

enum VisitStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model Visit {
  id String @id @default(uuid())

  visitCode String

  secureCode String @unique

  patientId String

  clinicId String

  createdById String

  visitStatus VisitStatus @default(OPEN)

  visitDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  clinic Clinic @relation(fields: [clinicId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])

  complaints Complaint[]

  @@unique([clinicId, visitCode])

  @@index([patientId])
  @@index([clinicId])
  @@index([visitDate])

  @@map("visits")
}